# Mood Journal 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# ============================================
# API 配置（必需）
# ============================================

# 开发环境 - 本地后端
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# 测试环境
# NEXT_PUBLIC_API_URL=https://api-test.moodjournal.app/v1

# 生产环境
# NEXT_PUBLIC_API_URL=https://api.moodjournal.app/v1

# ============================================
# 应用配置
# ============================================

NEXT_PUBLIC_APP_NAME=Mood Journal
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# 功能开关
# ============================================

# 启用数据同步功能
NEXT_PUBLIC_ENABLE_SYNC=true

# 启用用户注册
NEXT_PUBLIC_ENABLE_REGISTRATION=true

# ============================================
# 调试配置（仅开发环境）
# ============================================

# 启用调试模式
NEXT_PUBLIC_DEBUG=true

# ============================================
# 监控与分析（生产环境可选）
# ============================================

# Sentry错误追踪
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# 安全配置（服务端，不要暴露给客户端）
# ============================================

# JWT密钥
# JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# 加密密钥
# ENCRYPTION_KEY=your-encryption-key-min-32-characters
